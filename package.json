{
  "name": "mirror-in-seconds",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix my-app && npm install --prefix server",
    "dev:frontend": "npm run dev --prefix my-app",
    "dev:backend": "npm run dev --prefix server",
    "build:frontend": "npm run build --prefix my-app",
    "build": "npm run install:all && npm run build:frontend",
    "start:frontend": "npm run start --prefix my-app",
    "start:backend": "node server/index.js"
  }
}
